# MCP Memory Server Configuration
# Copy this file to .env and fill in your values.

# ============================================================================
# REQUIRED
# ============================================================================
OPENROUTER_API_KEY=your-api-key-here

# ============================================================================
# Server
# ============================================================================
MCP_PORT=8899
MCP_HOST=0.0.0.0
# Auth token for /start and /stop endpoints. Empty = open access.
MCP_AUTH_TOKEN=
# Alert endpoint for sending events to the main Go layer.
# Leave empty to disable. Format: http://localhost:3101
# Mode: optional (skip if down) or required (fail startup if not reachable)
ALERT_URL=
ALERT_MODE=optional

# ============================================================================
# llama.cpp — Embedding Server
# ============================================================================
LLAMA_PATH=llama-server
LLAMA_PORT=8080
LLAMA_HOST=0.0.0.0
LLAMA_MODEL_PATH=./model/qwen3-embedding-0.6b-Q8_0.gguf
LLAMA_CTX_SIZE=8192
LLAMA_GPU_LAYERS=999

# ============================================================================
# llama.cpp — Reranker Server
# ============================================================================
LLAMA_RERANKER_PORT=8081

# ============================================================================
# Hindsight — Memory API
# ============================================================================
HINDSIGHT_PATH=hindsight-api
HINDSIGHT_PORT=8888
HINDSIGHT_LLM_PROVIDER=openrouter
HINDSIGHT_LLM_MODEL=deepseek/deepseek-v4-flash
HINDSIGHT_EMBEDDINGS_PROVIDER=openai
HINDSIGHT_EMBEDDINGS_MODEL=qwen3-embedding-0.6b-Q8_0.gguf
HINDSIGHT_RERANKER_PROVIDER=cohere
HINDSIGHT_RERANKER_MODEL=./model/bge-reranker-base-Q4_k_m.gguf

# ============================================================================
# Cloud Embedding & Reranker (Optional)
# ============================================================================
# Set LLAMA_MODEL_PATH to an OpenAI-compatible embedding endpoint URL
# and HINDSIGHT_RERANKER_MODEL to a Cohere-compatible reranker endpoint URL
# to use cloud services instead of local llama.cpp.
#
# Example (OpenAI embedding + Cohere reranker):
#   LLAMA_MODEL_PATH=https://api.openai.com/v1
#   CLOUD_EMBEDDING_API_KEY=sk-...
#   CLOUD_EMBEDDING_URL=https://api.openai.com/v1
#   CLOUD_EMBEDDING_MODEL=text-embedding-3-small
#   HINDSIGHT_RERANKER_MODEL=https://api.cohere.com/v1/rerank
#   CLOUD_RERANKER_API_KEY=...
#   CLOUD_RERANKER_URL=https://api.cohere.com/v1/rerank
#   CLOUD_RERANKER_MODEL=rerank-english-v3.0
#   HINDSIGHT_EMBEDDINGS_PROVIDER=openai
#   HINDSIGHT_RERANKER_PROVIDER=cohere

CLOUD_EMBEDDING_API_KEY=
CLOUD_EMBEDDING_URL=
CLOUD_EMBEDDING_MODEL=

CLOUD_RERANKER_API_KEY=
CLOUD_RERANKER_URL=
CLOUD_RERANKER_MODEL=

# ============================================================================
# Service Timeouts
# ============================================================================
SERVICE_START_TIMEOUT=120s
SERVICE_STOP_TIMEOUT=5s
HEALTH_CHECK_TIMEOUT=60s
MCP_REQUEST_TIMEOUT=30s
MCP_RETRY_ATTEMPTS=3
MCP_RETRY_DELAY=1s
SHUTDOWN_TIMEOUT=10s

# ============================================================================
# Worker Pools
# ============================================================================
# Number of goroutines processing retain/reflect jobs.
# Each worker makes one Hindsight API call at a time.
# Retain uses LLM extraction (~6-8s); reflect uses LLM synthesis (~5-10s)
MEMORY_RETAIN_WORKERS=2
MEMORY_REFLECT_WORKERS=2
# Channel buffer size for pending jobs. Beyond this, HTTP handler blocks.
MEMORY_JOB_BUFFER=100

# ============================================================================
# Queue Timeouts
# ============================================================================
# How long an HTTP handler waits to push a job onto the channel before
# returning "server overloaded" to the agent.
MEMORY_QUEUE_PUSH_TIMEOUT=5s
# How long an HTTP handler waits for a worker to complete the job.
# Must be longer than the worst-case Hindsight LLM call.
MEMORY_QUEUE_RESPONSE_TIMEOUT=60s

# ============================================================================
# Sessions
# ============================================================================
# Maximum concurrent MCP sessions (SSE connections).
MCP_MAX_SESSIONS=100
# SSE channel buffer per session (outbound messages).
MCP_SSE_BUFFER=100
# Idle sessions older than this are cleaned up.
MCP_SESSION_IDLE=30m
# How often the session cleaner runs.
MCP_SESSION_CLEAN_INTERVAL=30s

# ============================================================================
# HTTP Server
# ============================================================================
HTTP_READ_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=120s
# 1 MiB = 1048576
HTTP_MAX_BODY_BYTES=1048576

# ============================================================================
# Health Monitor (auto-restart on failure)
# ============================================================================
# How often each service is pinged.
HEALTH_CHECK_INTERVAL=5s
# Number of consecutive failures before auto-restart.
HEALTH_CONSECUTIVE_FAILURES=2
